# Telemedicine Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# API Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telemedicine_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# MongoDB Configuration (if using MongoDB alongside PostgreSQL)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/telemedicine

# Firebase Configuration
# Option 1: Provide full JSON config as environment variable
# FIREBASE_CONFIG='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# Option 2: Provide path to JSON file (default is ./firebaseConfig.json)
FIREBASE_CONFIG_PATH=./firebaseConfig.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Redis Configuration (for session and caching)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# WebRTC Configuration
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVER_URL=your-turn-server-url
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@telemedicine.com

# File Storage Configuration
STORAGE_TYPE=local
# STORAGE_TYPE=aws-s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# Cloud Storage for Recording (optional)
RECORDING_STORAGE_URL=./recordings
MAX_RECORDING_SIZE=500MB

# Call Recording Configuration
ENABLE_CALL_RECORDING=true
RECORDING_QUALITY=medium

# Analytics Configuration
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# Video Constraints
DEFAULT_VIDEO_RESOLUTION=720p
MIN_VIDEO_RESOLUTION=360p
DEFAULT_FRAME_RATE=30
MIN_BANDWIDTH_MOBILE=0.5
MIN_BANDWIDTH_WIFI=1.0

# Security Headers
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=true

# Notification Service
NOTIFICATION_SERVICE=local
# NOTIFICATION_SERVICE=fcm
# FCM_PROJECT_ID=your-fcm-project-id
# FCM_PRIVATE_KEY=your-fcm-private-key

# Timeouts (in seconds)
CALL_TIMEOUT=30
SOCKET_PING_INTERVAL=25
SOCKET_PING_TIMEOUT=60

# Features
ENABLE_SCREEN_SHARING=true
ENABLE_FILE_SHARING=true
ENABLE_PRESCRIPTION_UPLOAD=true
ENABLE_CALL_ENCRYPTION=true

# Development Only
DEBUG=true
MOCK_DATA=true
