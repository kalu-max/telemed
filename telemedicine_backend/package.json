{
  "name": "telemedicine-video-backend",
  "version": "1.0.0",
  "description": "WebRTC video conferencing backend for telemedicine platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "db:init": "node scripts/initDatabase.js",
    "db:seed": "node scripts/initDatabase.js --seed",
    "db:reset": "node scripts/initDatabase.js --force --seed"
