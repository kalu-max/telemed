    "dotenv": "^16.0",
    "express": "^4.18",
    "express-rate-limit": "^6.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.0",
    "jsonwebtoken": "^9.0",
    "mongoose": "^7.0",
    "morgan": "^1.10",
    "multer": "^1.4",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6",
    "sequelize": "^6.35.0",
    "socket.io": "^4.5",
    "socket.io-client": "^4.5",
    "validator": "^13.9",
    "winston": "^3.8",
    "ws": "^8.14"
