{
  "name": "telemedicine-video-backend",
  "version": "1.0.0",
  "description": "WebRTC video conferencing backend for telemedicine platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "db:init": "node scripts/initDatabase.js",
    "db:seed": "node scripts/initDatabase.js --seed",
    "db:reset": "node scripts/initDatabase.js --force --seed",
    "migrate": "node scripts/migrate.js",
    "migrate:undo": "node scripts/migrate.js --undo",
    "migrate:status": "node scripts/migrate.js --status"
  },
  "keywords": [
    "webrtc",
    "video-conferencing",
    "telemedicine",
    "healthcare"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.4",
    "bcryptjs": "^2.4",
    "cors": "^2.8",
    "dotenv": "^16.0",
    "express": "^4.18",
    "express-rate-limit": "^6.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.0",
    "jsonwebtoken": "^9.0",
    "morgan": "^1.10",
    "multer": "^1.4",
    "nodemailer": "^8.0.2",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0",
    "socket.io": "^4.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.2",
    "winston": "^3.8"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.3"
  }
}
